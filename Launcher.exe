<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Silent Net</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/style.css">
    <link rel="stylesheet" href="/static/css/auth.css">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5"/>
                        <path d="M2 12l10 5 10-5"/>
                    </svg>
                    <span>Silent Net</span>
                </div>
                <h1 class="auth-title">Welcome back</h1>
                <p class="auth-subtitle">Sign in to your account</p>
            </div>

            
<div id="discordLogin">
    <button type="button" class="btn btn-discord" onclick="loginWithDiscord()">
        <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
        Login with Discord
    </button>

    <button type="button" class="auth-toggle" onclick="showCredentialsForm()">
        Sign in with credentials instead
    </button>
</div>

<div id="credentialsLogin" class="hidden">
    <form id="loginForm">
        <div class="form-group">
            <label class="form-label">User ID or Username</label>
            <input type="text" class="form-input" id="userId" name="userId" placeholder="Enter your user ID or username" required>
        </div>

        <div class="form-group">
            <label class="form-label">Account Key</label>
            <input type="password" class="form-input" id="accountKey" name="accountKey" placeholder="••••••••" required>
        </div>

        <div id="loginError" class="alert alert-danger hidden"></div>

        <button type="submit" class="btn btn-primary btn-full" id="loginBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/>
                <polyline points="10 17 15 12 10 7"/>
                <line x1="15" y1="12" x2="3" y2="12"/>
            </svg>
            Sign In
        </button>
    </form>

    <button type="button" class="auth-toggle" onclick="showDiscordLogin()">
        Sign in with Discord instead
    </button>
</div>


            <div class="auth-footer">
                
Don't have an account? <a href="/auth/signup">Sign up</a>

            </div>
        </div>
    </div>

    <script src="/static/js/app.js"></script>
    
<script>
document.getElementById('loginForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const errorDiv = document.getElementById('loginError');
    const loginBtn = document.getElementById('loginBtn');
    const userId = document.getElementById('userId').value.trim();
    const accountKey = document.getElementById('accountKey').value.trim();

    errorDiv.classList.add('hidden');
    loginBtn.disabled = true;
    loginBtn.innerHTML = 'Signing in...';

    try {
        const response = await fetch('/auth/login', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ userId, accountKey })
        });

        const data = await response.json();

        if (data.success) {
            window.location.href = data.redirect;
        } else {
            errorDiv.textContent = data.error || 'Login failed';
            errorDiv.classList.remove('hidden');
            loginBtn.disabled = false;
            loginBtn.innerHTML = `
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/>
                    <polyline points="10 17 15 12 10 7"/>
                    <line x1="15" y1="12" x2="3" y2="12"/>
                </svg>
                Sign In
            `;
        }
    } catch (err) {
        errorDiv.textContent = 'An error occurred. Please try again.';
        errorDiv.classList.remove('hidden');
        loginBtn.disabled = false;
        loginBtn.innerHTML = `
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/>
                <polyline points="10 17 15 12 10 7"/>
                <line x1="15" y1="12" x2="3" y2="12"/>
            </svg>
            Sign In
        `;
    }
});

function loginWithDiscord() {
    const state = btoa('login');
    window.location.href = '/auth/discord?initialState=' + encodeURIComponent(state);
}

function showCredentialsForm() {
    document.getElementById('discordLogin').classList.add('hidden');
    document.getElementById('credentialsLogin').classList.remove('hidden');
}

function showDiscordLogin() {
    document.getElementById('credentialsLogin').classList.add('hidden');
    document.getElementById('discordLogin').classList.remove('hidden');
}
</script>

</body>
</html>